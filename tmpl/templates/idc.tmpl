{{- /*gotype: github.com/bendusy/idc-alert-feishu/model.WebhookMessage*/ -}}
{
"msg_type": "interactive",
"card":
{
"header": {
"title": {
"tag": "plain_text",
"content": "{{json .TitlePrefix}}【{{json (projectCN (index .CommonLabels "project"))}}】{{with firstSummary .Alerts.Firing}}{{json .}} {{else}}{{if in .GroupLabels "alertname"}}{{json .GroupLabels.alertname}} {{end}}{{end}}{{if len .FiringAlerts}}🔥{{len .FiringAlerts}} Firing {{end}}{{if len .ResolvedAlerts}}✅{{len .ResolvedAlerts}} Resolved{{end}}"
},
"template":"{{if len .FiringAlerts}}{{maxSeverityColor .Alerts.Firing}}{{else}}green{{end}}"
},

"elements": [
{{range .FiringAlerts}}
    {
    "tag": "div",
    "text": {
    "tag": "lark_md",
    "content": "{{.}}"
    }
    },
    {
    "tag": "hr"
    },
{{ end }}
{{ range .ResolvedAlerts }}
    {
    "tag": "div",
    "text": {
    "tag": "lark_md",
    "content": "{{.}}"
    }
    },
    {
    "tag": "hr"
    },
{{ end }}
{
"tag": "note",
"elements": [
{
"tag": "lark_md",
"content": "{{range .Meta.SortedPairs}}{{ displayKV .Name .Value}}\t{{end}}{{ mentionIf .Alerts.Firing .OpenIDs }}"
}
]
}
]
}
}
